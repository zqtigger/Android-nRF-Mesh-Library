<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 网关信息栏 -->
            <TextView
                android:id="@+id/tvGatewayInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="8dp"
                android:background="#F5F5F5"
                android:text="网关未连接"
                android:textColor="#666"
                android:textSize="13sp" />

            <!-- 概览卡片区（3列 Grid） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#E3F2FD">
                    <TextView
                        android:id="@+id/cardSensorCount"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="传感器\n加载中..."
                        android:textColor="#1565C0"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:padding="8dp" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFF3E0">
                    <TextView
                        android:id="@+id/cardAlarmCount"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="告警\n加载中..."
                        android:textColor="#E65100"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:padding="8dp" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#E8F5E9">
                    <TextView
                        android:id="@+id/cardGatewayStatus"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="网关\n加载中..."
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:padding="8dp" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- 实时数据区 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="📍 实时数据"
                android:textColor="#333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecentData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="#FAFAFA"
                android:text="暂无数据"
                android:textColor="#333"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp" />

            <!-- 底部占位 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="64dp" />

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
